{
    "name": "xukera/core",
    "description": "Universal Knowledge Framework for PHP",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "knowledge",
        "graph",
        "framework",
        "semantic",
        "knowledge-graph"
    ],
    "authors": [
        {
            "name": "Dario Corrò"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Xukera\\Core\\": "core/",
            "Xukera\\Contracts\\": "contracts/",
            "Xukera\\Storage\\": "storage/",
            "Xukera\\Serialization\\": "serialization/",
            "Xukera\\Validation\\": "validation/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xukera\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
